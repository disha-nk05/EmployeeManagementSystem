<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Employee Management</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Bootstrap -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />

    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <style>
        body {
        margin: 0;
        font-family: Arial;
        }

        .sidebar {
        width: 220px;
        height: 100vh;
        background: #2c3e50;
        color: white;
        position: fixed;
        padding: 20px;
        }

        .sidebar h3 {
        color: #ecf0f1;
        }

        .sidebar a {
        color: white;
        display: block;
        margin: 15px 0;
        text-decoration: none;
        }

        .sidebar a:hover {
        color: #1abc9c;
        }

        .content {
        margin-left: 240px;
        padding: 20px;
        }
    </style>
</head>

<body>

    <!-- Sidebar -->
    <div class="sidebar">
        <h3>EMS</h3>
        <hr />
        <a href="/Employees/Index">👨 Employees</a>
        <a href="/Employees/Create">➕ Add Employee</a>
        <a href="/Account/Logout">🚪 Logout</a>
    </div>

    <!-- Main Content -->
    <div class="content">
        @RenderBody()
    </div>

    <!-- DEBUG (REMOVE LATER) -->
    <script>
        console.log("layout loaded");
    </script>

    <!-- Page Scripts -->
    @RenderSection("Scripts", required: false)

</body>
</html>